  <div class="flex w-max whitespace-nowrap animate-ticker-roll group-hover:[animation-play-state:paused]">
    <span class="font-sans font-extrabold text-md lg:text-2xl tracking-[5px] uppercase text-black/65 shrink-0">{seg}</span>
