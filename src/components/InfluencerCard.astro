---
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"

import InstagramIcon from "../svg/instagram.svg";
import TikTokIcon from "../svg/tiktok.svg";

const { name, lastname, textContent, social, i18nKey } = Astro.props
---

<Card className="w-[210px] sm:w-[230px] lg:w-full lg:max-w-[340px] bg-dark/[0.88] backdrop-blur-[16px] border border-gold/[0.18] rounded-3xl p-3.5 sm:p-4 lg:p-[20px_22px] shadow-2xl transition-all duration-300">
  <CardHeader className="p-0 flex flex-col space-y-1 pb-1.5 lg:pb-3">
    <CardTitle className="flex flex-wrap gap-x-1.5 gap-y-0.5 lg:flex-col font-beachday font-extrabold text-lg lg:text-3xl tracking-[1px] lg:tracking-[1.5px] text-white uppercase m-0 leading-[1.1] lg:leading-[1.3]">
      <div>{name}</div> 
      <div class="text-[#F7CB5C]">{lastname}</div>
    </CardTitle>
  </CardHeader>
  
  <CardContent className="p-0 space-y-2 lg:space-y-3">
    <p class="text-white text-[11px] lg:text-sm leading-relaxed" data-i18n={i18nKey}>{textContent}</p>
     
    <div class="flex flex-col gap-2 sm:grid sm:grid-cols-2 pt-2 lg:pt-3 border-t border-gold/[0.12]">
      
      <div class="flex items-center gap-1.5 lg:gap-2 w-full">
        <a href="#" class="social-btn w-8 h-8 lg:w-10 lg:h-10 bg-[#1a1a1a] rounded-full border border-gold flex items-center justify-center shrink-0 transition-transform duration-300 hover:scale-110" aria-label="Instagram">
          <span class="w-[14px] h-[14px] lg:w-[16px] lg:h-[16px] flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">
            <InstagramIcon />
          </span>
        </a>
        <div class="min-w-0 w-full">
          <span class="font-sans font-extrabold text-[11px] lg:text-[14px] text-gold block leading-none">{social.instagram.followers}</span>
          <span class="font-sans text-[8px] lg:text-[10px] text-white/40 block mt-0.5 whitespace-nowrap">{social.instagram.user}</span>
        </div>
      </div>

      <div class="flex items-center gap-1.5 lg:gap-2 sm:border-l sm:border-gold/[0.12] sm:pl-2 w-full">
        <a href="#" class="social-btn w-8 h-8 lg:w-10 lg:h-10 bg-[#1a1a1a] rounded-full border border-gold flex items-center justify-center shrink-0 transition-transform duration-300 hover:scale-110" aria-label="TikTok">
          <span class="w-[14px] h-[14px] lg:w-[16px] lg:h-[16px] flex items-center justify-center [&>svg]:w-full [&>svg]:h-full">
            <TikTokIcon />
          </span>
        </a>
        <div class="min-w-0 w-full">
          <span class="font-sans font-extrabold text-[11px] lg:text-[14px] text-gold block leading-none">{social.tiktok.followers}</span>
          <span class="font-sans text-[8px] lg:text-[10px] text-white/40 block mt-0.5 whitespace-nowrap">{social.tiktok.user}</span>
        </div>
      </div>

    </div>
  </CardContent>
</Card>