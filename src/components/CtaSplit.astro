---
import { Image } from 'astro:assets';
import ModelForBrands from '@/images/cta-dark-bg.jpg';
import TalentMonica from '@/images/talent-monica2.png';

import Button from './shared/Button.astro';
---

<section class="grid grid-cols-1 lg:grid-cols-2 bg-cream-2 overflow-hidden">

  <!-- BLOQUE MARCAS (IZQUIERDA) -->
  <div 
    class="relative bg-black px-6 pt-10 pb-8 md:px-12 md:py-16 md:min-h-[450px] lg:px-20 lg:py-[120px] lg:min-h-[580px] flex flex-col justify-end z-[1] lg:[clip-path:polygon(0_0,100%_0,85%_100%,0_100%)] lg:-mr-[5vw] lg:pr-[calc(20px+5vw)]"
  >
    <Image
      src={ModelForBrands}
      alt="Modelo para marcas"
      class="absolute inset-y-0 -left-[120px] h-full w-auto max-w-none object-cover object-top hidden md:block z-0"
    />

    <div 
      class="absolute inset-0 bg-gradient-to-r from-black/40 via-black/75 to-black hidden md:block z-[1]"
    ></div>

    <!-- Se agregaron md:ml-auto y md:max-w para empujar el texto a la derecha en iPad -->
    <div class="relative z-[2] anim from-l md:min-h-[300px] lg:min-h-[320px] flex flex-col justify-start md:max-w-[400px] lg:max-w-[440px] md:ml-auto w-full">
      <p class="font-black font-beachday text-[clamp(32px,4vw,48px)] leading-none text-gold-bright" data-i18n="cta.dark.label">
        PARA MARCAS
      </p>

      <p class="font-bold text-[20px] tracking-[0.5px] mt-2.5 lg:mt-4 text-cream/90" data-i18n="cta.dark.sub">
        Estrategia. Creatividad. Impacto real.
      </p>

      <p class="font-normal text-[16px] leading-[1.7] mt-3 lg:mt-4 text-white/[0.72]" data-i18n="cta.dark.body">
        Creamos campañas con propósito que conectan tu marca con las audiencias correctas y generan
        resultados que se sienten y se miden.
      </p>

      <div class="btn-container mt-4 lg:mt-auto">
        <Button
          href="https://qrkit.co/marcas"
          variant="gold"
          label="Cotizar campaña →"
          data-i18n="cta.dark.btn"
        />
      </div>
    </div>
  </div>

  <!-- BLOQUE CREADORES (DERECHA) -->
  <div class="relative bg-cream-2 px-6 pt-10 pb-8 md:px-12 md:py-16 md:min-h-[450px] lg:px-20 lg:py-[120px] lg:min-h-[580px] flex flex-col justify-end lg:pl-[5vw] overflow-hidden">

    <!-- Se ajustó la altura de la imagen en iPad con md:h-[420px] y lg:h-[550px] -->
    <Image
      src={TalentMonica}
      alt="Imagen de la influencer"
      class="absolute hidden md:block bottom-0 right-0 md:h-[420px] lg:h-[550px] w-auto object-contain pointer-events-none select-none z-0"
    />

    <div class="relative z-10 anim from-r d1 max-w-[360px] lg:min-h-[320px] flex flex-col justify-start">
      <p class="font-black font-beachday text-[clamp(32px,4vw,48px)] leading-none text-dark" data-i18n="cta.light.label">
        PARA CREADORES
      </p>

      <p class="font-bold text-[20px] tracking-[0.5px] mt-2.5 lg:mt-4 text-dark" data-i18n="cta.light.sub">
        Representación. Oportunidades. Crecimiento.
      </p>

      <p class="font-normal text-[16px] leading-[1.7] mt-3 lg:mt-4 text-steel" data-i18n="cta.light.body">
        Te representamos para que tu talento llegue más lejos con colaboraciones que suman a tu
        visión y a tu comunidad.
      </p>

      <div class="btn-container mt-4 lg:mt-auto">
        <Button
          href="https://qrkit.co/influencers"
          variant="outline"
          label="ÚNETE A LAMB →"
          data-i18n="cta.light.btn"
        />
      </div>
    </div>

  </div>

</section>

<style>
  .btn-container :global(a),
  .btn-container :global(button) {
    width: 100%;
    max-width: 280px;
    justify-content: center;
    text-align: center;
  }

  @media (max-width: 1023px) {
    .btn-container {
      display: flex;
      justify-content: center;
      width: 100%;
    }
  }
</style>