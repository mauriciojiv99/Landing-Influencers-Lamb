---
---

<section id="home-section" class="relative w-full min-h-screen overflow-hidden flex items-end xl:items-center">
  
  <video
    id="hero-video"
    playsinline
    autoplay
    muted
    loop
    class="absolute inset-0 w-full h-full object-cover z-0"
  >
    <source src="/videos/influencers.mp4" type="video/mp4" />
  </video>

  <button 
    id="audio-control"
    class="absolute top-6 right-6 md:top-10 md:right-12 z-[3] bg-black/60 hover:bg-black/80 text-white p-3.5 rounded-full backdrop-blur-sm transition-all duration-300 hover:scale-110 flex items-center justify-center cursor-pointer border border-white/10"
    aria-label="Alternar sonido"
  >
    <svg id="icon-muted" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />
    </svg>

    <svg id="icon-playing" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
    </svg>
  </button>

  <div class="relative z-[2] w-full max-w-[960px] mx-auto xl:ml-0 xl:mr-auto text-center xl:text-left pt-[240px] lg:pt-[280px] xl:pt-[160px] pb-16 px-6 lg:px-12 xl:pb-[100px] xl:pl-24">
    
    <a
      href="https://qrkit.co/marcas"
      target="_blank"
      class="inline-flex items-center justify-center gap-[10px] bg-gold text-white font-bold text-[13px] tracking-[1.6px] uppercase py-4 px-8 rounded-xl no-underline mt-8 xl:mt-12 transition-all duration-300 hover:bg-[#a8852e] hover:-translate-y-[3px]"
      data-i18n="hero.cta"
      style="animation: fadeIn 1s 1.4s both;"
    >
      Cotizar campaña &rarr;
    </a>
    
  </div>
</section>

<script>
  const video = document.querySelector('#hero-video') as HTMLVideoElement;
  const audioBtn = document.querySelector('#audio-control');
  const iconMuted = document.querySelector('#icon-muted');
  const iconPlaying = document.querySelector('#icon-playing');

  if (audioBtn && video && iconMuted && iconPlaying) {
    audioBtn.addEventListener('click', () => {
      video.muted = !video.muted;

      if (video.muted) {
        iconMuted.classList.remove('hidden');
        iconPlaying.classList.add('hidden');
      } else {
        iconMuted.classList.add('hidden');
        iconPlaying.classList.remove('hidden');
      }
    });
  }
</script>

