---
interface Stat {
  num: string;
  label: string;
  i18n: string;
  target?: number;
  prefix?: string;
  suffix?: string;
}

const stats: Stat[] = [
  { num: '100+', target: 100, suffix: '+', label: 'Campañas', i18n: 'stats.01.label' },
  { num: '03+', target: 3, prefix: '0', suffix: '+', label: 'Años redefiniendo el Management', i18n: 'stats.02.label' },
  { num: '20+', target: 20, suffix: '+', label: 'Creadores top en exclusiva', i18n: 'stats.03.label' },
];
---

<section
  class="px-6 py-16 md:px-12 md:py-24 lg:px-20 lg:py-[120px] overflow-hidden"
  style="background: radial-gradient(ellipse 65% 55% at 50% 30%, rgba(197,156,64,0.10) 0%, transparent 70%), #0b0b0b;"
>
  <div class="max-w-[920px] mx-auto text-center">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 lg:gap-12 mb-12 md:mb-16 lg:mb-24">
      {stats.map((s) => (
        <div class="anim text-center">
          <span
            class="stat__num font-light text-[52px] sm:text-[60px] lg:text-[clamp(60px,9vw,112px)] text-gold leading-none tracking-[-4px] block"
            data-target={s.target}
            data-prefix={s.prefix}
            data-suffix={s.suffix}
          >
            {s.num}
          </span>

          <p
            class="font-light italic text-[14px] lg:text-[clamp(13px,1.4vw,16px)] text-cream/60 mt-[6px] lg:mt-[10px] leading-[1.4]"
            data-i18n={s.i18n}
          >
            {s.label}
          </p>
        </div>
      ))}
    </div>

    <!-- Manifesto -->
    <div class="anim d2 text-left max-w-max mx-auto">

      <div class="inline-flex items-center gap-4 md:gap-7 leading-none flex-wrap">
        <span
          class="font-sans font-black text-[36px] sm:text-[52px] lg:text-[clamp(52px,7.5vw,88px)] text-white leading-none"
          data-i18n="stats.no"
        >
          NO
        </span>

        <span
          id="goldBar"
          class="block h-[3px] rounded-[2px] shrink-0 w-[60px] sm:w-[120px] lg:w-[clamp(80px,14vw,200px)]"
          aria-hidden="true"
          style="background: linear-gradient(90deg, #c59c40, rgba(197,156,64,0.12));"
        ></span>
      </div>

      <p
        class="font-sans font-black text-[36px] sm:text-[52px] lg:text-[clamp(52px,7.5vw,88px)] text-white leading-none m-0"
        data-i18n="stats.p1"
      >
        PERSEGUIMOS
      </p>

      <p
        class="font-sans font-black text-[36px] sm:text-[52px] lg:text-[clamp(52px,7.5vw,88px)] text-gold leading-none m-0 mb-6 md:mb-10"
        data-i18n="stats.p2"
      >
        TENDENCIAS.
      </p>

      <div class="flex flex-col items-baseline justify-start gap-2 md:gap-4">
        <span
          class="font-sans text-[30px] sm:text-[36px] lg:text-[clamp(36px,5.5vw,68px)] text-white leading-none"
          data-i18n="stats.p3"
        >
          Cultivamos
        </span>

        <span
          class="font-sans font-black text-[30px] sm:text-[36px] lg:text-[clamp(36px,5.5vw,68px)] text-white leading-none"
          data-i18n="stats.p4"
        >
          COMUNIDAD
        </span>
      </div>

    </div>

  </div>
</section>