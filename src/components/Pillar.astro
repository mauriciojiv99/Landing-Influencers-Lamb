---
interface Props {
  num: string;
  head: string;
  body: string;
  delay?: string;
}
const { num, head, body, delay } = Astro.props;
---

<div class:list={['pillar', 'anim', delay]}>
  <div class="pillar__num">{num}</div>
  <div>
    <div class="pillar__head">{head}</div>
    <p class="pillar__body">{body}</p>
  </div>
</div>

<style>
  .pillar {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    padding: 52px 0;
    border-top: 1px solid rgba(11, 11, 11, 0.12);
  }

  .pillar:last-child { border-bottom: 1px solid rgba(11, 11, 11, 0.12); }

  .pillar__num {
    font-weight: 700;
    font-size: 16px;
    color: var(--gold-alt);
    min-width: 56px;
    letter-spacing: 2px;
    padding-top: 6px;
  }

  .pillar__head {
    font-weight: 700;
    font-size: clamp(32px, 5vw, 60px);
    color: var(--dark);
    line-height: 1;
  }

  .pillar__body {
    font-weight: 400;
    font-size: 16px;
    color: var(--grey);
    line-height: 1.7;
    max-width: 520px;
    margin-top: 16px;
  }
</style>
